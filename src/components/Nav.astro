---
const base = import.meta.env.BASE_URL;
const allLinks = [
  { label: "about",      href: `${base}about` },
  { label: "work",       href: `${base}work`  },
  { label: "playground", href: "#playground"  },
];
---

<header
  id="site-nav"
  class="fixed top-0 left-0 right-0 z-50 px-6 md:px-10 lg:px-14 xl:px-20 2xl:px-32 py-4 md:py-5 flex items-center justify-between bg-bg/90 backdrop-blur-sm border-b border-primary/20 transition-all duration-300"
>
  <!-- Logo -->
  <a
    href={base}
    id="nav-logo"
    class="text-primary tracking-wide text-lg md:text-xl underline decoration-[1.5px] underline-offset-4 font-medium transition-all duration-300"
    style="text-decoration-color: var(--color-primary)"
  >
    achristmaschi
  </a>

  <!-- Mobile hamburger -->
  <button
    id="nav-toggle"
    class="md:hidden flex flex-col gap-[5px] p-2"
    aria-label="Toggle menu"
    aria-expanded="false"
    aria-controls="nav-mobile"
  >
    <span id="bar1" class="block w-6 h-[2px] bg-primary transition-transform duration-300" />
    <span id="bar2" class="block w-6 h-[2px] bg-primary transition-opacity duration-300" />
    <span id="bar3" class="block w-6 h-[2px] bg-primary transition-transform duration-300" />
  </button>

  <!-- Desktop nav -->
  <nav class="hidden md:block">
    <ul class="flex items-center gap-3 lg:gap-4">
      {allLinks.map(({ label, href }) => (
        <li>
          <a
            href={href}
            class="nav-link inline-flex items-center justify-center border-[1.5px] border-primary rounded-full px-5 py-1.5 lg:px-7 lg:py-2 text-base lg:text-lg italic text-primary font-medium tracking-wide transition-all duration-300 hover:bg-primary hover:text-bg bg-transparent"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <!-- Mobile nav overlay (hidden by default) -->
  <nav
    id="nav-mobile"
    class="hidden absolute top-full left-0 w-full bg-bg/95 backdrop-blur-sm md:hidden border-t border-primary/10 shadow-lg"
  >
    <ul class="flex flex-col">
      {allLinks.map(({ label, href }) => (
        <li class="w-full">
          <a
            href={href}
            class="nav-mobile-link flex items-center justify-center w-full py-5 text-lg italic text-primary font-medium tracking-wide border-b border-primary/10 transition-colors duration-200 hover:bg-primary/10"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById("nav-toggle")!;
  const menu   = document.getElementById("nav-mobile")!;
  const bar1   = document.getElementById("bar1")!;
  const bar2   = document.getElementById("bar2")!;
  const bar3   = document.getElementById("bar3")!;

  toggle.addEventListener("click", () => {
    const open = menu.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(open));
    bar1.classList.toggle("rotate-45",          open);
    bar1.classList.toggle("translate-y-[7px]",  open);
    bar2.classList.toggle("opacity-0",          open);
    bar3.classList.toggle("-rotate-45",         open);
    bar3.classList.toggle("-translate-y-[7px]", open);
  });

  // Close menu when a mobile link is tapped
  menu.querySelectorAll(".nav-mobile-link").forEach((link) => {
    link.addEventListener("click", () => {
      menu.classList.add("hidden");
      toggle.setAttribute("aria-expanded", "false");
      bar1.classList.remove("rotate-45", "translate-y-[7px]");
      bar2.classList.remove("opacity-0");
      bar3.classList.remove("-rotate-45", "-translate-y-[7px]");
    });
  });

  // Shrink nav on scroll
  const nav   = document.getElementById("site-nav")!;
  const logo  = document.getElementById("nav-logo")!;
  const links = nav.querySelectorAll<HTMLElement>(".nav-link");

  const COMPACT_NAV   = ["py-2",    "md:py-2.5"];
  const EXPANDED_NAV  = ["py-4",    "md:py-5"];
  const COMPACT_LOGO  = ["text-base",  "md:text-lg"];
  const EXPANDED_LOGO = ["text-lg",    "md:text-xl"];
  const COMPACT_LINK  = ["px-4",  "py-1",   "text-sm",  "lg:px-5"];
  const EXPANDED_LINK = ["px-5",  "py-1.5", "text-base", "lg:px-7", "lg:py-2", "lg:text-lg"];

  function applyCompact(compact: boolean) {
    nav.classList.toggle("py-4",      !compact);
    nav.classList.toggle("md:py-5",   !compact);
    nav.classList.toggle("py-2",       compact);
    nav.classList.toggle("md:py-2.5",  compact);

    logo.classList.toggle("text-lg",   !compact);
    logo.classList.toggle("md:text-xl",!compact);
    logo.classList.toggle("text-base",  compact);
    logo.classList.toggle("md:text-lg", compact);

    links.forEach((link) => {
      EXPANDED_LINK.forEach(c => link.classList.toggle(c, !compact));
      COMPACT_LINK.forEach(c  => link.classList.toggle(c,  compact));
    });
  }

  window.addEventListener("scroll", () => applyCompact(window.scrollY > 60), { passive: true });
</script>
